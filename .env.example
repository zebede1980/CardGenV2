# ============================================
# SillyTavern Character Generator Configuration
# ============================================
# Copy this file to .env and customize the values

# Port for the frontend web interface (default: 2427)
FRONTEND_PORT=2427

# Port for the backend proxy server (default: 2426)
PROXY_PORT=2426

# Frontend URL for CORS and API headers (auto-generated if not set)
# FRONTEND_URL=http://localhost:2427

# ── Authentication & Security ────────────────────────────────────────────────
# Secret key used for signing JWT authentication tokens.
# IMPORTANT: Change this to a long, random string in production!
JWT_SECRET=change-this-to-a-long-random-string

# Set to "true" to temporarily allow new user sign-ups (creation of new accounts).
# Set to "false" to disable registration once your user account(s) are created.
ALLOW_REGISTRATION=false

# ── Backend Configuration & Secrets ──────────────────────────────────────────
# Internal communication URL of the Story Writer backend service.
# If running via Docker Compose, use the service container name.
STORY_APP_URL=http://storywriterbackend:8000

# Optional: Public URL shown in the browser for the Story Writer tab.
# Leave empty unless you are proxying/serving the backend at a specific sub-domain.
STORY_APP_PUBLIC_URL=

# Shared secret key used for authentication between the proxy and FastAPI backend.
# IMPORTANT: Must match the secret set on the storywriterbackend container!
INTERNAL_API_SECRET=change-this-internal-secret

# ── Brave Search API ─────────────────────────────────────────────────────────
# Get your free API key (1,000 queries/month) at https://brave.com/search/api/
# Select the "Search" Data-for-AI plan, NOT the "Answers" plan.
BRAVE_SEARCH_API_KEY=
# Set to "false" to disable web search even if API key is configured
BRAVE_SEARCH_ENABLED=true

# ── Local Text-to-Speech (TTS) Configuration ─────────────────────────────────
# The voice/model to preload and use in the local Coqui TTS service container.
TTS_MODEL_NAME=tts_models/en/vctk/vits
# Hardware device to run Coqui TTS on. Use 'cuda' for GPU acceleration or 'cpu'.
TTS_DEVICE=cpu
# Whether to preload the model on startup.
TTS_PRELOAD=true
