# ============================================
# SillyTavern Character Generator Configuration
# ============================================
# Copy this file to .env and customize the values

# Port for the frontend web interface (default: 2427)
FRONTEND_PORT=2427

# Port for the backend proxy server (default: 2426)
PROXY_PORT=2426

# Frontend URL for CORS and API headers (auto-generated if not set)
# FRONTEND_URL=http://localhost:2427

# ── Brave Search API ─────────────────────────────────────────────────────────
# Get your free API key (1,000 queries/month) at https://brave.com/search/api/
# Select the "Search" Data-for-AI plan, NOT the "Answers" plan.
BRAVE_SEARCH_API_KEY=
# Set to "false" to disable web search even if API key is configured
BRAVE_SEARCH_ENABLED=true
